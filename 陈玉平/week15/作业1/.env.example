# Milvus Cloud Service Configuration
MILVUS_CLOUD_URI=https://xxx.milvus.io:19530
MILVUS_CLOUD_TOKEN=your_token_here

# MinerU Service
MINERU_API_URL=http://localhost:8000  # MinerU parse service endpoint
MINERU_API_KEY=your_api_key_here

# Qwen-VL Model
QWEN_VL_MODEL_PATH=Qwen/Qwen2-VL-7B-Instruct
QWEN_VL_DEVICE=cuda

# CLIP Model
CLIP_MODEL_NAME=openai/clip-vit-large-patch14

# BGE Model
BGE_MODEL_NAME=BAAI/bge-m3

# File Storage
UPLOAD_DIR=./uploads

# API Keys
QWEN_API_KEY=your_qwen_api_key

# Kafka
KAFKA_BROKERS=localhost:9092